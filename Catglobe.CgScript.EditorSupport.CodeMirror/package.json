{
  "name": "@catglobe/cgscript-codemirror",
  "version": "0.1.0",
  "description": "CodeMirror 6 LSP client integration for CgScript (.cgs) files",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p ./"
  },
  "dependencies": {
    "@codemirror/lsp-client": "^6.1.1"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "@codemirror/state": "^6.0.0",
    "@codemirror/view":  "^6.0.0"
  },
  "license": "MIT",
  "keywords": ["codemirror", "cgscript", "lsp"]
}
