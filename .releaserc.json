{
  "defaultBranch": "main",
  "branches": [
    "+([0-9])?(.{+([0-9]),x}).x",
    "main",
    "next",
    "next-major",
    {
      "name": "beta",
      "prerelease": true
    },
    {
      "name": "alpha",
      "prerelease": true
    }
  ],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@droidsolutions-oss/semantic-release-update-file",
      {
        "files": [
          {
            "path": [
              "Catglobe.CgScript.Runtime/Catglobe.CgScript.Runtime.csproj",
              "Catglobe.CgScript.Common/Catglobe.CgScript.Common.csproj",
              "Catglobe.CgScript.Deployment/Catglobe.CgScript.Deployment.csproj",
              "Catglobe.CgScript.EditorSupport.Parsing/Catglobe.CgScript.EditorSupport.Parsing.csproj",
              "Catglobe.CgScript.EditorSupport.Lsp/Catglobe.CgScript.EditorSupport.Lsp.csproj",
              "Catglobe.CgScript.EditorSupport.SourceGenerator/Catglobe.CgScript.EditorSupport.SourceGenerator.csproj",
              "Catglobe.CgScript.EditorSupport.VisualStudio/Catglobe.CgScript.EditorSupport.VisualStudio.csproj"
            ],
          "type": "xml",
          "replacements": [
              { "key": "Version", "value": "${nextRelease.version}" },
              { "key": "RepositoryCommit", "value": "${nextRelease.gitHead}" }
            ]
          }
        ]
      }
    ],
    [
      "@droidsolutions-oss/semantic-release-nuget",
      {
        "projectPath": [
          "Catglobe.CgScript.Runtime/Catglobe.CgScript.Runtime.csproj",
          "Catglobe.CgScript.Common/Catglobe.CgScript.Common.csproj",
          "Catglobe.CgScript.Deployment/Catglobe.CgScript.Deployment.csproj",
          "Catglobe.CgScript.EditorSupport.Parsing/Catglobe.CgScript.EditorSupport.Parsing.csproj",
          "Catglobe.CgScript.EditorSupport.Lsp/Catglobe.CgScript.EditorSupport.Lsp.csproj",
          "Catglobe.CgScript.EditorSupport.SourceGenerator/Catglobe.CgScript.EditorSupport.SourceGenerator.csproj",
          "Catglobe.CgScript.EditorSupport.VsCode/Catglobe.CgScript.EditorSupport.VsCode.csproj"
        ],
        "includeSymbols": true
      }
    ],
    [
      "semantic-release-vsce",
      {
        "packageVsix": true,
        "packageRoot": "Catglobe.CgScript.EditorSupport.VsCode",
        "publish": false
      }
    ],
    [
      "@semantic-release/github",
      {
        "addReleases": "top",
        "assets": [
          { "path": "cgscript-vscode*.vsix", "name": "cgscript-vscode-${nextRelease.version}.vsix", "label": "VS Code Extension" },
          { "path": "Catglobe.CgScript.EditorSupport.VisualStudio/bin/Release/**/Catglobe.CgScript.EditorSupport.VisualStudio.vsix", "name": "cgscript-vs-${nextRelease.version}.vsix", "label": "Visual Studio Extension" }
        ]
      }
    ]
  ]
}
