<Project Sdk="Microsoft.NET.Sdk.Razor">

   <PropertyGroup>
      <PackageId>Catglobe.CgScript.EditorSupport.CodeMirror.AspNet</PackageId>
      <Version>0.1.0</Version>
      <Authors>Dennis Haney</Authors>
      <Company>Voxmeter A/S</Company>
      <description>CodeMirror 6 browser bundle for CgScript (.cgs) files, distributed as an ASP.NET Core static web asset. Files are served at /_content/Catglobe.CgScript.EditorSupport.CodeMirror.AspNet/</description>
      <RepositoryType>git</RepositoryType>
      <RepositoryUrl>https://github.com/catglobe/Catglobe.ScriptDeployer</RepositoryUrl>
      <PackageLicenseExpression>MIT</PackageLicenseExpression>
      <PackageReadmeFile>README.md</PackageReadmeFile>
   </PropertyGroup>

   <PropertyGroup>
      <TargetFramework>net9.0</TargetFramework>
      <Nullable>enable</Nullable>
      <ImplicitUsings>enable</ImplicitUsings>
      <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
      <!-- Run npm bundle generation before PrepareForBuild so the wwwroot file exists
           when ResolveProjectStaticWebAssets and ResolveCurrentProjectStaticWebAssetsInputs
           scan @(Content) for static web assets. Without this, clean builds miss the file. -->
      <PrepareForBuildDependsOn>BuildNpmBundle;$(PrepareForBuildDependsOn)</PrepareForBuildDependsOn>
   </PropertyGroup>

   <ItemGroup>
      <Content Include="../README.md">
         <Pack>true</Pack>
         <PackagePath></PackagePath>
      </Content>
   </ItemGroup>

   <!-- Explicit Content item with relative path so ResolveCurrentProjectStaticWebAssetsInputs
        picks it up (it filters @(Content) by identity starting with 'wwwroot/'). -->
   <ItemGroup>
      <Content Include="wwwroot\cgscript-cm6.js" />
   </ItemGroup>

   <!-- Build the TypeScript bundle via the dedicated npm project.
        Incremental: skip if inputs unchanged and output already exists. -->
   <ItemGroup>
      <_NpmSources Include="$(MSBuildThisFileDirectory)../Catglobe.CgScript.EditorSupport.CodeMirror/src/**/*.ts" />
      <_NpmSources Include="$(MSBuildThisFileDirectory)../Catglobe.CgScript.EditorSupport.CodeMirror/package-lock.json" />
   </ItemGroup>

   <Target Name="BuildNpmBundle"
           Inputs="@(_NpmSources)"
           Outputs="$(MSBuildThisFileDirectory)wwwroot/cgscript-cm6.js">
      <MSBuild Projects="$(MSBuildThisFileDirectory)../Catglobe.CgScript.EditorSupport.CodeMirror/Catglobe.CgScript.EditorSupport.CodeMirror.csproj"
               Targets="BuildNpmBundle" />
   </Target>

</Project>
