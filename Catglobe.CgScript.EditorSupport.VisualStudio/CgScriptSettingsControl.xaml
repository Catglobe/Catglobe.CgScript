<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StackPanel Margin="12" MinWidth="360">

    <TextBlock FontWeight="SemiBold" Margin="0,0,0,8">Site URL</TextBlock>
    <TextBox Text="{Binding SiteUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
             ToolTip="Base URL of the Catglobe site, e.g. https://localhost:5001" />

    <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,4,0,12">
      Base URL of the Catglobe site to fetch live definitions from
      (e.g. https://localhost:5001). Leave empty to use the bundled definitions.
    </TextBlock>

    <Button Command="{Binding SaveCommand}" HorizontalAlignment="Left">Save</Button>

    <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,8,0,0" FontStyle="Italic">
      Restart Visual Studio for changes to take effect.
    </TextBlock>

  </StackPanel>
</DataTemplate>
