	JAVA_SCRIPT = "function CommuneChanged(ev, question) {
  var options = question.getAnswer();
  var region = question.answerSheet.questions.match('label', 'Region')[0];
  window.dontAutoScroll = window.initial;
  if (options.length)
    region.setAnswer(communeToRegion.get(options[0].value));
  else
    region.resetAnswer();
  window.dontAutoScroll = false;
}
Question.bind('afterShowQuestion', CommuneChanged);
Question.bind('answerChanged', CommuneChanged);

Question.bind('afterValidateQuestion', function(ev, question, state) {
  var answers = question.answerOptions.getAnswer();
  if ((answers.length && communeToRegion.get(answers[0].value)) || !question.answerRequired) return;
  question.attr('errorMessage', 'Angiv postnummer/kommune');
  state.valid = false;
});

