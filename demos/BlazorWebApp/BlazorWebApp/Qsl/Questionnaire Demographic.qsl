QUESTION Inet_Access MULTI
[
	AUTO_ARRANGE_ANSWER_OPTIONS = false;
	ANSWER_OPTION_COLUMNS = 1;
	JAVA_SCRIPT = "function InetAccessChanged(ev, question) {
  var inetUsageFrequencePrivatQuestion = question.answerSheet.questions.match('label', 'Inet_UsageFrequence_Privat')[0];
  var inetUsageFrequenceWorkQuestion = question.answerSheet.questions.match('label', 'Inet_UsageFrequence_Work')[0];
  var options = question.getAnswer();
  var enable = !options.some(x => x.value === 5 || x.value === 6);
  var haswork = enable && options.some(x => x.value === 2);
  window.dontAutoScroll = true;
  if (enable) {
    inetUsageFrequencePrivatQuestion.answerRequired = true;
    inetUsageFrequenceWorkQuestion.answerRequired = true;
    inetUsageFrequencePrivatQuestion.elements().parent().show();
    inetUsageFrequenceWorkQuestion.elements().parent().show();
  } else {
    inetUsageFrequencePrivatQuestion.answerRequired = false;
    inetUsageFrequencePrivatQuestion.elements().parent().hide();
    if (inetUsageFrequencePrivatQuestion.attr('answer') && !window.initial) inetUsageFrequencePrivatQuestion.attr('answer', '');
  }
  if (!haswork) {
    inetUsageFrequenceWorkQuestion.answerRequired = false;
    inetUsageFrequenceWorkQuestion.elements().parent().hide();
    if (inetUsageFrequenceWorkQuestion.attr('answer') && !window.initial) inetUsageFrequenceWorkQuestion.attr('answer', '');
  }
  window.dontAutoScroll = false;
}
Question.bind('afterShowQuestion', InetAccessChanged);
Question.bind('answerChanged', InetAccessChanged);";
]
