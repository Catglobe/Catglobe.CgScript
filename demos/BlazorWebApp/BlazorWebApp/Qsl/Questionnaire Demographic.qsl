QUESTION Household_Children_Below_18 SINGLE
[
	AUTO_ARRANGE_ANSWER_OPTIONS = false;
	ANSWER_OPTION_COLUMNS = 1;
	JAVA_SCRIPT = "function HouseholdChildrenChanged(ev, question) {
  var options = question.getAnswer();
  var below18AgeQuestion = question.answerSheet.questions.match('label', 'Children_Age')[0];
  var nrKids = options.length ? options[0].value - 1 : 0; //subtract 1 since value 1 is 0 kids

  if (nrKids === 0) {
    below18AgeQuestion.elements().parent().hide();
  } else {
    below18AgeQuestion.elements().parent().show();
    below18AgeQuestion.elements().find('.cg-ui-grid-row').hide();
    below18AgeQuestion.elements().find('.cg-ui-grid-row:lt(' + nrKids + ')').show();
  }
  below18AgeQuestion.subQuestions.forEach((x, i) => x.attr('answerRequired', i < nrKids));
}
Question.bind('afterShowQuestion', HouseholdChildrenChanged);
Question.bind('answerChanged', HouseholdChildrenChanged);";
]
