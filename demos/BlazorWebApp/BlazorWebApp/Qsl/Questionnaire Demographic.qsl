Question_saveQuestions(dataToSave, QAS_getCurrentQAS());
*/
Dictionary thisQnaireLabels = Question_getAll()
	.ToDictionary(function(array q) {
		return q[QUESTION_LABEL];
	});

QAS res_curr = QAS_getCurrentQAS().GetCaller();
if (res_curr == empty) { //testing this qnaire directly
	if (thisQnaireLabels.ContainsKey(\"Extra_Gender\")) thisQnaireLabels.Remove(\"Gender\");
	STAM_COPY_DATA = Catglobe.Json.Encode(thisQnaireLabels.Keys); //show all
	return;
}

Dictionary allLabelsInSource = Question_getAll(res_curr[QAS_QUESTIONNAIRE_RESOURCE_ID])
	.ToDictionary(function(array q) {
		return q[QUESTION_LABEL];
	});
Dictionary labelsToCopy = allLabelsInSource.KeysWhere(function(string q, array val) {
		return thisQnaireLabels.ContainsKey(q);
	})
	.ToDictionary(function(string x) {
		return x;
	});

if (labelsToCopy.Count == 0) returnFromGoto(); //nothing to do

array allQas = getRPQUserId() == empty ? {} : QAS_getByUserResourceId(0, 15004111); //Panel Demographics DK (new) - Block 01 – Basis demografi
if (!allLabelsInSource.ContainsKey(\"COPY_DATA_FROM_STAM\") || allQas.Count == 0) { //not a panel member or dont use panel, show all questions asked for
	allQas = getRPQUserId() == empty ? {} : QAS_getByUserResourceId(0, 15916154);
	if (!allLabelsInSource.ContainsKey(\"COPY_DATA_FROM_STAM\") || allQas.Count == 0) {
		if (labelsToCopy.ContainsKey(\"Extra_Gender\")) labelsToCopy.Remove(\"Gender\");
		STAM_COPY_DATA = Catglobe.Json.Encode(labelsToCopy.Keys);
		return;
	}
}

Dictionary dataMap = {
	\"Gender\": \"Gender\",
	\"Extra_Gender\": \"Extra_Gender\",
	\"Age\": \"Age\",
	\"Region\": \"Region\",
	\"ZipCode\": \"ZipCode\",
	\"Commune_2007\": \"Commune_2007\",
	\"Civil_Status\": \"Civil_Status\",
	\"Household_Size\": \"Household_Size\",
	\"Household_Children_Below_18\": \"Household_Children_Below_18\",
	\"Children_Age\": \"Children_Age\",
	\"DK_Living_Type\": \"DK_Living_Type\",
	\"DK_Living_Form\": \"DK_Living_Form\",
	\"ShoppingResponsibility\": \"ShoppingResponsibility\",
	\"Car_In_Household\": \"Car_In_Household\",
	\"Lower_Education\": \"Lower_Education\",
	\"Higher_Education\": \"Higher_Education\",
	\"DK_Personal_Income\": \"DK_Personal_Income\",
	\"DK_Household_Income\": \"DK_Household_Income\",
	\"DK_Household_Style\": \"DK_Household_Style\",
	\"Inet_Access\": \"Inet_Access\",
	\"Inet_UsageFrequence\": \"Inet_UsageFrequence\",
	\"DK_Household_Pets\": \"DK_Household_Pets\",
	\"Current_Professional_Status\": \"Current_Professional_Status\",
};
Dictionary demographics = Question_loadQuestions(dataMap.KeysWhere(function(string key, string map) {
	return labelsToCopy.ContainsKey(map);
}), allQas[0]);
Dictionary dataToSave = demographics.Keys.ToDictionary(function(string label) {
	return dataMap[label];
}, function(string label) {
	return demographics[label];
});

if (dataToSave.TryGetValue(\"Inet_UsageFrequence\") != empty) {
	dataToSave[\"Inet_UsageFrequence_Work\"] = dataToSave[\"Inet_UsageFrequence\"][0];
	dataToSave[\"Inet_UsageFrequence_Privat\"] = dataToSave[\"Inet_UsageFrequence\"][1];
}

if (dataToSave.TryGetValue(\"Household_Size\") == 1) dataToSave[\"Household_Children_Below_18\"] = 1;
//if (dataToSave.TryGetValue(\"Gender\") != empty && dataToSave.TryGetValue(\"Extra_Gender\") == empty) dataToSave[\"Extra_Gender\"] = dataToSave[\"Gender\"];

// luu add code to adjust kids age to current year
if (dataToSave.TryGetValue(\"Children_Age\") != empty && dataToSave.ContainsKey(\"Household_Children_Below_18\")) {
	array arrChildren_Age = dataToSave[\"Children_Age\"];
	number countChildrenBelow18 = 0;
	array dateTime = getDateTime();
	number year_ = dateTime[DateTime_Year];
	for (i
		for 0; arrChildren_Age.Count) {
		string kidBirthYear = arrChildren_Age[i];
		if (kidBirthYear == empty) continue;
		//we stored year of birth of the kid, ensure they are still below 18
		if (year_ - convertToNumber(kidBirthYear) > 18) arrChildren_Age[i] = empty;
		else countChildrenBelow18++;
	}
	dataToSave[\"Children_Age\"] = arrChildren_Age;
	dataToSave[\"Household_Children_Below_18\"] = countChildrenBelow18 >= 5 ? 6 : countChildrenBelow18 + 1; //+1, because 1 is 0 children
}

//find the questions we want to the user to see and confirm, even if we have data
array confirmInfoQ = allLabelsInSource.TryGetValue(\"CONFIRM_STAMDATA\");
Dictionary confirmInfo;
if (confirmInfoQ != empty)
	confirmInfo = confirmInfoQ[QUESTION_ANSWER_OPTIONS].ToDictionary(function(array ao) {
		return trim(stripHtml(ao[ANSWEROPTION_TEXT]));
	});

array dataToSaveKeys = dataToSave.Keys;
array questionsToActuallyDisplay;
for (i
	for 0; dataToSaveKeys.Count) {
	if (dataToSave[dataToSaveKeys[i]] == empty || confirmInfo.ContainsKey(dataToSaveKeys[i]))
		questionsToActuallyDisplay.Add(dataToSaveKeys[i]);
}
if (questionsToActuallyDisplay.Contains(\"Extra_Gender\")) questionsToActuallyDisplay.Remove(\"Gender\");
dataToSave[\"STAM_COPY_DATA\"] = questionsToActuallyDisplay.Count > 0 ? Catglobe.Json.Encode(questionsToActuallyDisplay) : empty;

Question_saveQuestions(dataToSave, QAS_getCurrentQAS());";
]
calculate and store json encoded list of question labels to display

