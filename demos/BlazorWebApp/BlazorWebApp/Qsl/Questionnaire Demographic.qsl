QUESTION Household_Size SINGLE
[
	AUTO_ARRANGE_ANSWER_OPTIONS = false;
	ANSWER_OPTION_COLUMNS = 1;
	JAVA_SCRIPT = "function HouseholdSizeChanged(ev, question) {
  var options = question.getAnswer();
  var below18Question = question.answerSheet.questions.match('label', 'Household_Children_Below_18')[0];
  var nrPeople = options.length ? options[0].value : 1;

  if (nrPeople == 1) {
    below18Question.elements().parent().hide();
    below18Question.attr('answer', 1);
  } else {
    if (below18Question.attr('answer') && !window.initial)
    	below18Question.attr('answer', '');
    below18Question.elements().parent().show();
    below18Question.elements().find('.cg-ui-grid-row').hide();
    below18Question.elements().find('.cg-ui-grid-row:lt(' + nrPeople + ')').show();
  }
}
Question.bind('afterShowQuestion', HouseholdSizeChanged);
Question.bind('answerChanged', HouseholdSizeChanged);";
]
