QUESTION SETUPSTAMDATA PAGE
[
	JAVA_SCRIPT = "//Bind this after afterShowQuestion, so that any changes on init doesnt trigger the scrolling
window.dontAutoScroll = false; //set before changing values programatically
window.initial = true;
function autoScroll(ev, answerSheet, qnaire, el) {
  window.initial = false;
  answerSheet.unbind('afterShowPage', autoScroll); //just do once
  //determine if we need to show a given question
  var questionLabelsToShow = new Map(JSON.parse('{{STAM_COPY_DATA}}').map(i => [i, 1]));
  //show these together
  [\"ZipCode\", \"Commune_2007\", \"Region\"].forEach((e, i, arr) => {
    if (questionLabelsToShow.get(e))
      arr.forEach(y => questionLabelsToShow.set(y, 1));
  });
  //show these together
  [\"Household_Size\", \"Household_Children_Below_18\", \"Children_Age\"].forEach((e, i, arr) => {
    if (questionLabelsToShow.get(e))
      arr.forEach(y => questionLabelsToShow.set(y, 1));
  });
  //Also show these, if this question is needed
  if (questionLabelsToShow.get(\"Inet_UsageFrequence\"))
    [\"Inet_Access\", \"Inet_UsageFrequence_Work\", \"Inet_UsageFrequence_Privat\"].forEach(y => questionLabelsToShow.set(y, 1));
  answerSheet.questions.forEach((q, i, arr) => {
    var show = questionLabelsToShow.get(q.label);
    q.attr('answerRequired', !!show);
    var questionEle = q.elements().parent();
    if (show) {
      //support scroll to next
      q.bind('answerChanged', _ => {
        //dont goto next if current has error
        if (typeof(q.validate) === \"function\" && !q.validate()) return;
        if (window.dontAutoScroll) return;
        if (q.type == 2 || q.type == 6 || q.type == 7 || q.type == 8 || q.type == 12) return; //all the multi-style question
        var nextQ = arr[i + 1];
        var off = 1;
        //find first next visible question
        while (nextQ && !nextQ.elements().is(\":visible\"))
          nextQ = arr[i + (++off)];
        if (nextQ) {
          $([document.documentElement, document.body]).stop().animate({
            scrollTop: nextQ.elements().offset().top - 30
          }, 100);
          nextQ.elements().find('input').first().focus();
        } else {
			setTimeout(()=>$(\".navigation-panel .next\").first().focus(), 0); //let any current js finish          
        }
      });
      //first list is those that take care of their own visibily during init
      if ([\"Commune_2007\", \"Household_Children_Below_18\", \"Children_Age\", \"Inet_UsageFrequence_Work\", \"Inet_UsageFrequence_Privat\"].indexOf(q.label) === -1) {
	    //list here is the questions only shown based on values of other questions
        if ([\"Region\"].indexOf(q.label) !== -1)
          questionEle.hide();
        else
          questionEle.show();
      }
    } else {
      questionEle.hide();
      //viewer ignores answerRequired on question, if there are still subquestions that are required
      q.subQuestions.forEach(x => x.attr('answerRequired', false));
    }
  });
  el.show(); //always show this page, which is the title
}
Question.answerSheet.bind('afterShowPage', autoScroll);";
]
