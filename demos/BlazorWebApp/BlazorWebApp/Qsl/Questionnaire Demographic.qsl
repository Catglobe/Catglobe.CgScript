QUESTION Age NUMBER
[
	MIN_VALUE = 11;
	MAX_VALUE = 120;
	JAVA_SCRIPT = "function handleChangeInAge(ev, q) {
  var year = parseInt(ev.target.value);
  if (year < 14 || year >= 120) return;
  if (!window.initial) q.attr('answer', year); //trigger autoscroll
}
Question.bind('afterShowQuestion', function(ev, question) {
  handleChangeInAge({
    target: {
      value: question.attr('answer')
    }
  }, question);
  $(question.elements()[0]).find('input').on('input', e => handleChangeInAge(e, question));
});";
]
Hvad er din alder?

QUESTION ZipCode NUMBER
[
	MIN_VALUE = 0;
	MAX_VALUE = 9999;
	JAVA_SCRIPT = "function handleChangeInZip(ev, q) {
  var commune = q.answerSheet.questions.match('label', 'Commune_2007')[0];
  commune.answerOptions.elements().hide();
  var zip = parseInt(ev.target.value);
  var possible = zipcodeMapToCommune.get(zip);
  commune.elements().parent().toggle(!!possible && possible.length > 1);
  if (possible) {
    commune.answerOptions.grep(x => possible.includes(x.value)).elements().show(); //show the possible commune
    window.dontAutoScroll = window.initial;
    if (!commune.getAnswer().find(x => possible.includes(x.value))) //reset answer if prev answer isnt shown anymore
      commune.resetAnswer();
	q.attr('answer', zip); //trigger next
    if (possible.length === 1) commune.setAnswer(possible[0]);
    window.dontAutoScroll = false;
  }
}
Question.bind('afterShowQuestion', function(ev, question) {
  handleChangeInZip({
    target: {
      value: question.attr('answer')
    }
  }, question);
  $(question.elements()[0]).find('input').on('input', e => handleChangeInZip(e, question));
});

Question.bind('afterValidateQuestion', function(ev, question, state) {
  if (zipcodeMapToCommune.get(question.answer) || !question.answerRequired) return;
  question.attr('errorMessage', question.answer ? 'Det angivne postnummer eksisterer ikke i Danmark. Brug 0 hvis du bor i udlandet.' : 'Angiv postnummer');
  state.valid = false;
});

