QUESTION D_COPY_STAMDATA_BACK PAGE
[
	DUMMY = true;
	CG_SCRIPT = "Dictionary newData = Question_loadQuestions();
if (Gender == empty && Extra_Gender != empty) Gender = Extra_Gender == [1, 3] ? 1 : 2;
if (Gender != empty && Extra_Gender == empty) Extra_Gender = Gender;
if (Gender != empty && Age != empty) {
  if (Gender == 1 && Age == [18 - 34]) D_Age_Gender = 1;
  if (Gender == 1 && Age == [35 - 49]) D_Age_Gender = 2;
  if (Gender == 1 && Age == [50 - 64]) D_Age_Gender = 3;
  if (Gender == 1 && Age == [65 - 120]) D_Age_Gender = 4;
  if (Gender == 2 && Age == [18 - 34]) D_Age_Gender = 5;
  if (Gender == 2 && Age == [35 - 49]) D_Age_Gender = 6;
  if (Gender == 2 && Age == [50 - 64]) D_Age_Gender = 7;
  if (Gender == 2 && Age == [65 - 120]) D_Age_Gender = 8;
}
if (Age != empty) {
  if (Age == [18 - 34]) D_Age_Group = 1;
  if (Age == [35 - 49]) D_Age_Group = 2;
  if (Age == [50 - 64]) D_Age_Group = 3;
  if (Age == [65 - 120]) D_Age_Group = 4;
}
if (Inet_UsageFrequence_Work != empty || Inet_UsageFrequence_Privat != empty) {
  Inet_UsageFrequence[0] = Inet_UsageFrequence_Work;
  Inet_UsageFrequence[1] = Inet_UsageFrequence_Privat;
}


Dictionary thisQnaireLabels = Question_getAll()
  .ToDictionary(function(array q) {
    return q[QUESTION_LABEL];
  });

QAS res_curr = QAS_getCurrentQAS().GetCaller();
if (res_curr == empty) //testing this qnaire directly
  return;

Dictionary allLabelsInSource = Question_getAll(res_curr[QAS_QUESTIONNAIRE_RESOURCE_ID])
  .ToDictionary(function(array q) {
    return q[QUESTION_LABEL];
  });

Dictionary labelsToCopy = allLabelsInSource.KeysWhere(function(string q, array val) {
    return thisQnaireLabels.ContainsKey(q);
  })
  .ToDictionary(function(string key) {
    return key;
  }, function(string key) {
    return newData[key];
  });

if (labelsToCopy.Count > 0)
  Question_saveQuestions(labelsToCopy, res_curr);

//if we asked for any questions and prop says to copy back or we are calling this qas directly
if (STAM_COPY_DATA != empty && getRPQUserId() != empty && allLabelsInSource.ContainsKey(\"UPDATE_DATA_IN_STAM\")) {
  array allQas = QAS_getByUserResourceId(0, 15004111); //Panel Demographics DK (new) - Block 01 – Basis demografi
  if (allQas.Count > 0) { //only for a panel member
    Dictionary dataMap = {
      \"Gender\": \"Gender\",
		\"Extra_Gender\": \"Extra_Gender\",
      \"Age\": \"Age\",
      \"Region\": \"Region\",
      \"ZipCode\": \"ZipCode\",
      \"Commune_2007\": \"Commune_2007\",
      \"Civil_Status\": \"Civil_Status\",
      \"Household_Size\": \"Household_Size\",
      \"Household_Children_Below_18\": \"Household_Children_Below_18\",
      \"Children_Age\": \"Children_Age\",
      \"DK_Living_Type\": \"DK_Living_Type\",
      \"DK_Living_Form\": \"DK_Living_Form\",
      \"ShoppingResponsibility\": \"ShoppingResponsibility\",
      \"Car_In_Household\": \"Car_In_Household\",
      \"Lower_Education\": \"Lower_Education\",
      \"Higher_Education\": \"Higher_Education\",
      \"DK_Personal_Income\": \"DK_Personal_Income\",
      \"DK_Household_Income\": \"DK_Household_Income\",
      \"DK_Household_Style\": \"DK_Household_Style\",
      \"Inet_Access\": \"Inet_Access\",
      \"Inet_UsageFrequence\": \"Inet_UsageFrequence\",
      \"DK_Household_Pets\": \"DK_Household_Pets\",
      \"Current_Professional_Status\": \"Current_Professional_Status\",
		\"Year_Born\":\"Year_Born\"
    };
    //we dont use labelsToCopy, because some questions depends on answers of other questions, so anything that we now have data for is stored back to panel
    Dictionary dataToSave = newData.Keys.Where(function(string key) {
        return dataMap.ContainsKey(key) && newData[key] != empty;
      })
      .ToDictionary(function(string key) {
        return dataMap[key];
      }, function(string key) {
        return newData[key];
      });
    Question_saveQuestions(dataToSave, allQas[0]);
  }
}

returnFromGoto();";
]
Copy data back to asker and if needed to panel also

