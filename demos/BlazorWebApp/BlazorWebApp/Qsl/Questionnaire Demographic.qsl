6:5 eller flere

QUESTION Children_Age TEXTGRID
[
	QUESTION_STYLE_SHEET = "#Children_Age-question table {
	width: 300px;
}
#Children_Age-question input {
	width: 100px;
}";
	JAVA_SCRIPT = "/*Question.bind('afterValidateQuestion', function(ev, question, state) {
	if (!question.answerRequired) return;
	var year = new Date().getFullYear();
	question.subQuestions.forEach(x => {
		if (!x.attr('answerRequired')) {
			//clean up excesive answers if someone lowered the number of kids
			if (x.attr('answer'))
				x.attr('answer', '');
			return;
		}
		var a = parseInt(x.attr('answer')) || 0;
		if (a > year || a < (year - 18)) {
			x.attr('state', Questionnaire.Models.QuestionState.Error);
			question.attr('errorMessage', \"Indtast dit barns fødselsår (skal være mellem \" + (year - 18) + \" og \" + year + \")\");
			state.valid = false;
			question.elements().parent().show(); //some people may have invalid data which causes it to fail, so ensure it is shown so respondent can see the problem
		}
	});
});*/
Question.bind('afterValidateQuestion', function(ev, question, state) {
	if (!question.answerRequired) return;
	var year = new Date().getFullYear();
	question.subQuestions.forEach(x => {
		if (!x.attr('answerRequired')) {
			//clean up excesive answers if someone lowered the number of kids
			if (x.attr('answer'))
				x.attr('answer', '');
			return;
		}
		var a = parseInt(x.attr('answer')) || 0;
		if (isNaN(x.attr('answer')) || a > year || a < (year - 18)) {
			x.attr('state', Questionnaire.Models.QuestionState.Error);
			question.attr('errorMessage', \"Indtast dit barns fødselsår (skal være mellem \" + (year - 18) + \" og \" + year + \")\");
			state.valid = false;
			question.elements().parent().show(); //some people may have invalid data which causes it to fail, so ensure it is shown so respondent can see the problem
		}
	});
});";
]
