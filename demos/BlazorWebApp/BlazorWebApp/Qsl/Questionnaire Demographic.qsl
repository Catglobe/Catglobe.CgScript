  dataToSave[\"Inet_UsageFrequence_Privat\"] = dataToSave[\"Inet_UsageFrequence\"][1];
}

if (dataToSave.TryGetValue(\"Household_Size\") == 1) dataToSave[\"Household_Children_Below_18\"] = 1;
if (dataToSave.TryGetValue(\"Gender\") != empty && dataToSave.TryGetValue(\"Extra_Gender\") == empty) dataToSave[\"Extra_Gender\"] = dataToSave[\"Gender\"];

// luu add code to adjust kids age to current year
if (dataToSave.TryGetValue(\"Children_Age\") != empty && dataToSave.ContainsKey(\"Household_Children_Below_18\")) {
