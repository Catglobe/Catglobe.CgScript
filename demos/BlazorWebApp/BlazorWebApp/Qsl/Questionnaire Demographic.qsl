	AUTO_ARRANGE_ANSWER_OPTIONS = false;
	ANSWER_OPTION_COLUMNS = 1;
	JAVA_SCRIPT = "Question.bind('answerChanged', function(ev, question) {
  var options = question.getAnswer();
  var hasCars = options.some(x=>x.value <= 3);
  var householdStyleQuestion = question.answerSheet.questions.match('label', 'DK_Household_Style')[0];

  window.dontAutoScroll = true;
  if (hasCars) {
    if (!householdStyleQuestion.getAnswer().some(x=>x.value === 1))
      householdStyleQuestion.setAnswer(1);
  } else {
    if (householdStyleQuestion.getAnswer().some(x=>x.value === 1))
      householdStyleQuestion.toggleAnswer(1);
  }
  window.dontAutoScroll = false;
});";
]
