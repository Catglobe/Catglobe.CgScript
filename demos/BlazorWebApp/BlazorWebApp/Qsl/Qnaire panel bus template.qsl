.test(a.substr(0, 4))) check = true;
	})(navigator.userAgent || navigator.vendor || window.opera);
	return check;
};

can.Control.extend('Viewer.AnswerOptionsDropdownController', {},
{
   init: function (element) {
      // Get the question model
      var question = element.instance();

      // On selected attribute change
      question.answerOptions.each(function(a, i) {
         a.bind('selected', function(ev) {
            a.elements().prop('selected', a.selected);
         });
      });
   },

   change: function (ui, ev) {
      var question = this.element.instance();
      var answerOption = this.element.find('option:selected').instance() || null;
      if (answerOption === null) {
         question.resetAnswer();
      }
      else {
         question.attr('answer', answerOption.value);
      }
   }

});

//
// Modified single question template which displays answer options in a drop-down list
//
Viewer.registerTemplate('single_question_dropdown_list', \"<div id=\\\"<%= attr('label') %>-question\\\" class=\\\"cg-ui-question cg-ui-state-normal\\\" <%= this %> <%= (el) -> new Viewer.SingleQuestionController(el) %>>   <div class=\\\"cg-ui-error-message cg-ui-hidden\\\"></div>   <div class=\\\"cg-ui-text\\\"><%== attr('text') %></div>   <div>      <select style=\\\"width: 100%;height:30px\\\" <%= this %> <%= (el) -> new Viewer.AnswerOptionsDropdownController(el) %>>         <option>Angiv et svar...</option>         <% list(answerOptions, function(a, i) { %>         <option value='<%= a.attr('value') %>' <%= a.attr('selected') ? 'selected' : '' %> <%= a %> <%= (el) -> el.html(a.attr('text')) %> ></option>         <% }) %>      </select>   </div></div>\");

can.Control.extend('Viewer.AnswerScaleNumber', {},
{
   // Control initialization
      init: function (element) {
         var model = this.options.model;
         var view = this.options.view;
      },

      // Event handlers
      '{model} answer': function (_, ev) {
         var model = this.options.model;
         var view = this.element;
            view.find('.cg-ui-answer-option').each(function (i, e) {
               if (model.attr('answer') !== null && model.attr('minimum') + i * model.attr('step') == model.attr('answer')) {
                  $(e).addClass('cg-ui-selected');
               }
               else {
                  $(e).removeClass('cg-ui-selected');
               }
            });
      },
   
   '.cg-ui-answer-option click': function (ui, ev) {
         var model = this.options.model;
         model.attr('answer', model.attr('answer') != ui.data('value') ? ui.data('value') : null);
      }

});
can.view.ejs('number_scale', \"\\<div id=\\\"<%= attr('label') %>-question\\\" class=\\\"cg-ui-question cg-ui-state-normal\\\" <%= this %> <%= (el) -> new Viewer.ScaleQuestionController(el) %>>   <div class=\\\"cg-ui-error-message cg-ui-hidden\\\"></div>   <div class=\\\"cg-ui-text\\\"><%== attr('text') %></div>   <div class=\\\"cg-ui-scale-placeholder  <%= (el) -> new Viewer.AnswerScaleNumber(el, { model: this }) %>\\\">    <table class=\\\"cg-ui-scale\\\" cellspacing=\\\"0\\\" cellpadding=\\\"0\\\">    <tr>    <th class=\\\"cg-ui-text first\\\" colspan=\\\"<%=  Math.floor((attr('minimum')+attr('maximum'))/(attr('step')*2)) %>\\\"><img src=\\\"http://voxmeter.dk/wp-content/uploads/2016/02/negative.png\\\"/><span class=\\\"left_tilte\\\"><%= attr('minimumText') %></span></th>     <th class=\\\"cg-ui-text last\\\" colspan=\\\"<%=  Math.floor((attr('minimum')+attr('maximum'))/(attr('step')*2))+1 %>\\\"><span class=\\\"right_tilte\\\"><%= attr('maximumText') %></span><img src=\\\"http://voxmeter.dk/wp-content/uploads/2016/02/positive.png\\\"/></th>    </tr>    <tr>    <% for (var i = attr('minimum'); i <= attr('maximum'); i += attr('step')) { %>    <td class=\\\"cg-ui-answer-option <%= attr('answer') == i ? ' cg-ui-selected' : \\'' %>\\\" data-value=\\\"<%= i %>\\\">    <span><%= i %></span>    </td>    <% } %>    </tr> </table>   </div></div>\");
";
]

QUESTION README PAGE
[
	DUMMY = true;
	CG_SCRIPT = "/*if (getRPQUserId() != empty && !getRPQTest()) {
	QAS qas = new QAS(getRPQId());
	Quarantine_addToQuarantine(20339292, {
		qas.UserResourceId
	}, \"After start survey: \" + qas.QuestionnaireResourceId);
};*/";
]
<p><span style="font-size:28px;"><span style="color:#e74c3c;">MUST DO</span></span></p><p>1. Before sending out, add the questionnaire to panel bus using <a href="https://voxmeter.catglobe.com/ReportModule/DashboardModule/DashboardViewer5.aspx?id=580">https://voxmeter.catglobe.com/ReportModule/DashboardModule/DashboardViewer5.aspx?id=580</a></p><p>2. Double check <strong>D_GivePoints</strong></p><p><strong><span style="font-size:20px;">Stam data</span></strong></p><p>This questionnaire utilizes a discovery based approach to figuring out which data to copy from stam data.</p><p>There are a number of Questions involved in the code to support this:</p><p><strong>Goto_Collect_Stam</strong>: This question is where the action takes place. Upon visiting this question, the code will redirect the user to a questionnaire that will detect which questions are needed and ensure proper syncronization between this questionnaire and stam data questionnaire.</p><p>You may move this question around freely to choose when the user is expected to fill out the questions. Ofcourse, if you depend on the Stam data for screening it must be before the <strong>CHECK_SCREENING</strong>, and if you depend on Stam data in your quotas, it must be before the <strong>CHECK_QUOTA</strong>.</p><p><strong><strong>ANY question whose label matches a question in <a href="https://voxmeter.catglobe.com/QuestionnaireModule/Editor/QuestionnaireJsEditor.aspx?id=4091&amp;pq=5927">15916154 ([Panel Bus] - Questionnaire Demographics data - New layout)</a></strong>:</strong> The <strong><strong>15916154 </strong></strong>questionnaire will use these labels to determine which questions needs to be copied. Per default most of the questions from <strong><strong>15916154 </strong></strong>are already included, so if you do NOT wish for some data to be copied simply <span style="color:#f39c12;"><strong>delete </strong></span>them from this questionnaire. Per default these questions are grouped in block named <strong>StamQuestions</strong>, but this is not a necessity.</p><p>You can open the above link and use QSL to get the optional StamQuestions, such as Year_Born, DK_Household_Style, DK_Household_Pets, Inet_Access, Inet_UsageFrequence. Simply export them from there, and import them here and mark as dummy questions.</p><p><strong>COPY_DATA_FROM_STAM:</strong> The presence of a question with this label will inform the <strong>Goto_Collect_Stam</strong> phase that it needs to pull the Stam data from the background questionnaire. It would be extremely rare you don&#39;t want this, as this will force the user to answer all of the necessary Stam data questions again.</p><p><strong>UPDATE_DATA_IN_STAM</strong>: The presence of a question with this label will inform the <strong>Goto_Collect_Stam</strong> phase that it needs to update any changed Stam data back into the background questionnaire.</p><p><strong>CONFIRM_STAMDATA</strong>: Any answer options in this question will always be shown during <strong>Goto_Collect_Stam</strong> phase.<br /><strong><span style="font-size:20px;">Screening</span></strong></p><p>This questionnaire utilizes the showif conditions to evaluate the screening conditions.</p><p>See further documentation in the <strong>CHECK_SCREENING </strong>question.</p><p><strong><span style="font-size:20px;">Awarding respondents (Give points)</span></strong></p><p>Giving points to the respondent is a setting in the properties tab that you can set in any question and it can be in any location in the questionnaire.</p><p>The questionnaire engine will automatically give the points when the respondent goes over that question, and if the respondent uses the back button to go behind that question again they are subtracted again.</p><p>However, for this template the default place where this is done is in the <strong>D_GivePoints</strong> question, which per default is located at the end of the block <strong>INSERT_QUESTIONS_HERE</strong>, which is the end of the survey.</p><p><strong>REMEMBER</strong> to also set the text to display in the transaction, since otherwise the questionnaire name is used which might inform the respondent about the which client the survey is for, which may not be what you want.</p><p>The 2nd step for the reward ceremony is to inform the user that they got some points. This is done in the <strong>Goto_HowToSpendYourPoints </strong>question, where the respondent is redirected to a special questionnaire that lets them pick what to spend their points on.<br /><strong><span style="font-size:20px;">Done Sequence (hidden)</span></strong></p><p>In the question <strong>D_Initialize</strong> a number of common data items are collected:</p><ul><li><strong>D_Browser</strong>: This contains the browser identification string, useful for debugging if people are complaining about some clientside technical issue</li><li><strong>D_Device</strong>: This contains the type of device used, e.g. tablet, desktop, phone</li><li><strong>D_Week</strong>: This contains a sortable date that contains the week that the qas was started in. This is necessary for any tracking questionnaires, where this is used as the foundation of the date grouping.</li><li><strong>D_Date</strong>:This contains a sortable date that contains the day that the qas was started in. In some scripts this may be easier to use than depending on the QAS started date.</li></ul><p>This is followed by the evaluation:</p><p>In the <strong>Goto_Evaluate </strong>question we randomly sample 20% of the respondents to fill out the feedback survey. You can change the percentage by altering the expression of the showIf condition of the question.</p><p>If they return from the evaluation, we jump to panel bus again in<strong> Goto_PanelBus</strong> to let them continue with their next qas.</p><p>The <strong>End</strong> is only used for testing.</p>

GROUP G_Intro SEQUENCE QUESTIONS

QUESTION D_Info_Point TEXTGRID
[
	DUMMY = true;
	CG_SCRIPT = "string D_Browser = getServerVariable(HTTP_USER_AGENT);
number D_Device = empty;
if (D_Browser != empty) {
	number mobile = indexOf(\"Mobile\", D_Browser);
	number iPhone = indexOf(\"iPhone\", D_Browser);
	number tablet = indexOf(\"Android\", D_Browser);
	number iPad = indexOf(\"iPad\", D_Browser);
	if ((mobile != empty && iPad == empty) || (iPhone != empty && iPad == empty))
		D_Device = 3;
	else if (iPad != empty || (tablet != empty && mobile == empty))
		D_Device = 2;
	else D_Device = 1;
}

array dateTime = getDateTime();
number wyear;
if (convertToNumber(dateTime[DateTime_Week]) > 51 && convertToNumber(dateTime[DateTime_Month]) == 1) wyear = dateTime[DateTime_Year] - 1;
else if (convertToNumber(dateTime[DateTime_Week]) == 1 && convertToNumber(dateTime[DateTime_Month]) == 12) wyear = dateTime[DateTime_Year] + 1;
else wyear = dateTime[DateTime_Year];
Question_saveQuestions({
	\"D_Browser\": D_Browser,
	\"D_Device\": D_Device,
	\"D_Week\": (wyear * 100) + convertToNumber(dateTime[DateTime_Week]),
	\"D_Date\": (dateTime[DateTime_Year] * 10000) + (convertToNumber(dateTime[DateTime_Month]) * 100) + convertToNumber(dateTime[DateTime_Day]),
}, QAS_getCurrentQAS());

number introRId = 19914860;
QAS introPage = QAS_getByUserResourceId(0, introRId, true, getRPQTest())[0];
Question_saveQuestions({
	\"ResourceQuestionnaireID\": QAS_getCurrentQAS()[QAS_QUESTIONNAIRE_RESOURCE_ID],
	\"RPQID_Resource\": QAS_getCurrentQAS().Id,
	\"TrackSource\": 2
}, introPage);
introPage.Reset();
introPage.GotoQuestionnaire(); //never returns";
]
<p>Store info point that respondent will get it when they complete survey</p><p>0. Point number</p><p>1. Minute number</p>
SQ:[Please type point number at here]
SQ:[Please type minute number at here]

END

