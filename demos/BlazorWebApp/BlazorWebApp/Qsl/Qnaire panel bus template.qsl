QUESTION D_GivePoints PAGE
IF (getRPQUserId()!=empty && !getRPQTest())
[
	DUMMY = true;
	ANSWER_SHEET_STATUS = 5;
	POINTS = 1;
	POINTS_TRANSACTION_TEXT = "Tak for at udfylde skema";
	CG_SCRIPT = "object getDate = function(array time) {
	array dateTime = time;
	return (dateTime[DateTime_Year] * 10000) + (convertToNumber(dateTime[DateTime_Month]) * 100) + convertToNumber(dateTime[DateTime_Day]);
};
object check_Partly = function(number userRID) {
	array date_time = getDateTime();
	array list_qniare = stringSplit(getStringConstant(\"Qnaire_Rid\", 15525202), \",\");
	array list_qniare_active = {};
	for (i
		for 0; list_qniare.Count) {
		Questionnaire qnaire = new Questionnaire(convertToNumber(list_qniare[i]));
		if (qnaire.Status == 3 && convertToNumber(list_qniare[i]) != [20056100, 20105748]) arrayAdd(list_qniare_active, convertToNumber(list_qniare[i]));
	}
	if (userRID != empty && list_qniare_active != empty && User_getUserByResourceId(userRID).ResourceTemplateResourceId == 1846) {
		array qasS = QAS_getByUserResourceId(userRID, list_qniare_active);
		qasS = qasS.Where(function(array a) {
			!a[QAS_TEST] && !a[QAS_COMPLETED] && a[QAS_STARTDATE][DateTime_Year] != 1 && a[QAS_STARTDATE][DateTime_Month] != 1 && a[QAS_STARTDATE][DateTime_Day] != 1 && getDate.Call(a[QAS_STARTDATE]) != getDate.Call(date_time);
		});
		if (qasS != empty) return false;
		else return true;
	} else return true;
};
QAS qas = new QAS(getRPQId());
Dictionary checkIfQuarantined = Quarantine_checkIfQuarantined({
	20339292
}, {
	qas.UserResourceId
});
if (checkIfQuarantined[convertToString(qas.UserResourceId)] && check_Partly.Call(qas.UserResourceId)) Quarantine_removeFromQuarantine(20339292, {
	qas.UserResourceId
});
";
]
Set Number of points given in this survey in the properties tab

