[
	HTML = true;
	REQUIRED = true;
	AUTO_ARRANGE_ANSWER_OPTIONS = true;
	NEXT_BUTTON_VISIBLE = true;
	JAVA_SCRIPT = "$(function() {
    $('head').append('<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge,chrome=1\"/>');
});
AnswerSheet.bind('afterShowPage', function(ev, answerSheet, questionnaire) {
    $('head').append('<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge,chrome=1\"/>');
    var isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);
    if (isMobile) $('head').append('<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1, user-scalable=0\" />');
	//$(\"html, body\", window.document).animate({ scrollTop: 0 }, 1000);
	$(\"html, body\", window.document).animate({ scrollTop: 0 },1);
});
AnswerSheet.bind('afterCompleted', function(ev, answerSheet, questionnaire) {
    $('.pr_success').css('width','100%');
	$('.pr_success').css('margin-left','-10px');
	$('.pr_total').css('width','100%');
});
AnswerSheet.bind('afterShowPage', function(ev, answerSheet, questionnaire) {
	//$(\"html, body\", window.document).animate({ scrollTop: 0 }, 1000);
	$(\"html, body\", window.document).animate({ scrollTop: 0 },1);
    $('head').append('<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge,chrome=1\"/>');
    var isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);
    if (isMobile) $('head').append('<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1, user-scalable=0\" />');
	/*Fix for question multi*/
	$(\".cg-ui-answer-option\").click(function(){
		if($(\".multi_question\").find(\".cg-ui-selected\"))
		{
			$(\".cg-ui-error-message\").addClass(\"cg-ui-hidden\");
		};
	});
	/*Fix for question singlegrid*/
	$(\".cg-ui-answer-option\").click(function(){
		if(isMobile)$(this).parent().removeClass(\"cg-ui-state-error\");
		else{
			$(\".cg-ui-error-message\").addClass(\"cg-ui-hidden\");
			$(this).parent().parent().removeClass(\"cg-ui-state-error\");
		};
	});
	/*Fix for question single*/
	$(\".cg-ui-answer-option\").click(function(){
		if($(\".cg-ui-grid-row\").find(\".cg-ui-selected\"))
		{
			$(\".cg-ui-error-message\").addClass(\"cg-ui-hidden\");
		};
	});
});
AnswerSheet.bind('beforeShowPage', function(ev, answerSheet, questionnaire) {
	if (mobilecheck() && (answerSheet.questions[0].type == 1 || answerSheet.questions[0].type == 2)) {
		for (var i = 0; i < answerSheet.questions.length; i++) {
			answerSheet.questions[i].answerOptionColumns = 1;
			answerSheet.questions[i].answerOptionRows = answerSheet.questions[i].answerOptions.length;
		}
	}
});
