QUESTION D_Speeders_Start TEXT
IF (false)
[
	DUMMY = true;
	CG_SCRIPT = "D_Speeders_Start = DateTime_objToInvariant(new DateTime(getDateTime()));
if (getRPQUserId() != empty && !getRPQTest()) {
	QAS qas = new QAS(getRPQId());
	Dictionary checkIfQuarantined = Quarantine_checkIfQuarantined({
		20339292
	}, {
		qas.UserResourceId
	});
	if (!checkIfQuarantined[convertToString(qas.UserResourceId)]) Quarantine_addToQuarantine(20339292, {
		qas.UserResourceId
	}, \"After start survey: \" + qas.QuestionnaireResourceId);
};";
]
