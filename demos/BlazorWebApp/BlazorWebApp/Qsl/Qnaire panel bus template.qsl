if (SoMe_Target != empty) {
	for (i
		for 0; SoMe_Target.Count) {
		SoMe_Target[i] = convertToNumber(SoMe_Target[i]);
	};
};
QAS qas = new QAS(getRPQId());
if (SoMe_Target != empty && SoMe_Target.Contains(qas.QuestionnaireResourceId)) {
	WorkflowScript wfScript = new WorkflowScript(20507958);
	wfScript.Call({
		\"Event\": \"Purchased\",
		\"UserId\": qas.UserResourceId
	});
}";
]
End API

QUESTION D_Speeders_End SINGLE
IF (getRPQUserId()!=empty && !getRPQTest() && D_Speeders_Start!=empty)
[
	DUMMY = true;
	CG_SCRIPT = "array questionProperty = getQuestionProperties(\"D_GivePoints\");
number qpp;
for (i
	for 0; questionProperty.Count) {
	QuestionProperty qpx = questionProperty[i];
	if (qpx.QuestionPropertyTypeAsString == \"EndPoints\" && qpx.Value != empty) qpp = convertToNumber(qpx.Value);
};
D_Speeders_End = 2;
QAS qas = new QAS(getRPQId());
array list_all_question = Question_getAll(qas.QuestionnaireResourceId);
array list_view = qas.ViewedQuestions;
array list_question;
if (list_view == empty) return;
else {
	for (i
		for 0; list_view.Count) {
		if (!list_question.Contains(list_all_question[list_view[i]][3])) arrayAdd(list_question, list_all_question[list_view[i]][3]);
	}
}
array list_question_cal;
for (j
	for 0; list_question.Count) {
	array listOfQuestionProperty = getQuestionProperties(list_question[j], qas.QuestionnaireResourceId);
	bool flag = false;
	for (number i = 0; i < listOfQuestionProperty.Count; i++) {
		QuestionProperty qp = listOfQuestionProperty[i];
		if (qp.PropertyTypeAsString == \"Dummy\" || qp.PropertyTypeAsString == \"End\") flag = true;
		if (qp.QuestionPropertyTypeAsString == \"EndPoints\" && qp.Value != empty) qpp = convertToNumber(qp.Value);
	}
	if (!flag) arrayAdd(list_question_cal, list_question[j]);
}
Dictionary d = Question_loadQuestions(list_question_cal, qas);
for (i
	for 0; d.Count) {
	if (d[d.Keys[i]] == empty) list_question_cal.RemoveItemAt(i);
}
object e;
try {
	for (i
		for 0; d.Count) {
		if (d[d.Keys[i]].AsValue() == empty) list_question_cal.RemoveItemAt(i);
	}
} catch (e) {}
if (list_question_cal != empty && D_Speeders_Start != empty) {
	number times = DateTime_secondsBetween(DateTime_fromInvariant(D_Speeders_Start), getDateTime()) / list_question_cal.Count;
	if (times < 3 && false) {
		QAS speedersWarning = QAS_getByUserResourceId(0, 19925070, true, getRPQTest())[0];
		speedersWarning.Reset();
		Dictionary warning = Question_loadQuestions({
			\"D_Warning_Time\",
			\"D_Warning_QAS\",
			\"D_List_Question_Calculator\",
			\"D_Time_Question\"
		}, speedersWarning);
		object Compare = function(array time1, array time2) {
			return DateTime_daysBetween(time1, time2);
		};
		if (warning[\"D_Warning_Time\"][0] != empty && warning[\"D_Warning_Time\"][1] != empty && warning[\"D_Warning_Time\"][2] != empty) return;
		DateTime dt = new DateTime(getDateTime());
		if (warning[\"D_Warning_Time\"][0] == empty) {
			warning[\"D_Warning_Time\"][0] = DateTime_objToInvariant(dt);
			warning[\"D_Warning_QAS\"][0] = getRPQId();
			warning[\"D_List_Question_Calculator\"][0] = convertToString(list_question_cal);
			warning[\"D_Time_Question\"][0] = times;
			Question_saveQuestions(warning, speedersWarning);
			D_Speeders_End = 1;
			User_withdrawPoints(qpp, \"Your points has been canceled due to your answer being unsatisfactory\");
			setRPQStatus(RPQ_Status_InterviewFailed);
			setRPQCompleted(true);
			speedersWarning.GotoQuestionnaire();
		} else if (warning[\"D_Warning_Time\"][1] == empty && Compare.Call(DateTime_fromInvariant(warning[\"D_Warning_Time\"][0]), getDateTime()) <= 182) {
			warning[\"D_Warning_Time\"][1] = DateTime_objToInvariant(dt);
			warning[\"D_Warning_QAS\"][1] = getRPQId();
			warning[\"D_List_Question_Calculator\"][1] = convertToString(list_question_cal);
			warning[\"D_Time_Question\"][1] = times;
			Question_saveQuestions(warning, speedersWarning);
			D_Speeders_End = 1;
			User_withdrawPoints(qpp, \"Your points has been canceled due to your answer being unsatisfactory\");
			setRPQStatus(RPQ_Status_InterviewFailed);
			setRPQCompleted(true);
			speedersWarning.GotoQuestionnaire();
		} else if (warning[\"D_Warning_Time\"][2] == empty && Compare.Call(DateTime_fromInvariant(warning[\"D_Warning_Time\"][0]), getDateTime()) <= 182) {
			warning[\"D_Warning_Time\"][2] = DateTime_objToInvariant(dt);
			warning[\"D_Warning_QAS\"][2] = getRPQId();
			warning[\"D_List_Question_Calculator\"][2] = convertToString(list_question_cal);
			warning[\"D_Time_Question\"][2] = times;
			Question_saveQuestions(warning, speedersWarning);
			D_Speeders_End = 1;
			User_withdrawPoints(qpp, \"Your points has been canceled due to your answer being unsatisfactory\");
			setRPQStatus(RPQ_Status_InterviewFailed);
			setRPQCompleted(true);
			speedersWarning.GotoQuestionnaire();
		}
	}
}";
